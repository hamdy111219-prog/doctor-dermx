# Copy this file to .env (for local `netlify dev`) and ALSO set the same
# variables in Netlify -> Site settings -> Environment variables for production.

# --- Required (server-side only, never exposed to the browser) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional: enables saving sessions to Supabase ---
# Found in Supabase -> Project Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...

# Note: the browser uses the PUBLIC anon key, which is set in public/config.js
# (not here). The service-role key above is server-side only.
